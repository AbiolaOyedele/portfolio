NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional / not yet configured — required only for admin service-role operations.
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_EMAIL=admin@example.com

# Optional / not yet configured — Sentry error monitoring is not wired up yet.
SENTRY_DSN=

# Cloudinary — unsigned browser uploads from the admin. Both are public
# (NEXT_PUBLIC). The upload preset must be configured as "Unsigned" in
# Cloudinary. Leave blank to disable the upload widget (paste-URL still works).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
